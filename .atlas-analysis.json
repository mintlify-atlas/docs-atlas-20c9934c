{
  "projectType": "sdk-library",
  "projectName": "LIgeodesics",
  "projectDescription": "A MATLAB toolbox for computing left- and right-invariant Riemannian geodesics on matrix Lie groups, with closed-form implementations for common groups including SO(n), SE(n), SIM(n), GL(n), and more.",
